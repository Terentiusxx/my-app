'use client'

import React, { useEffect, useRef } from 'react'
import MuxPlayer from '@mux/mux-player-react'
import gsap from 'gsap'
import { ScrollTrigger } from 'gsap/ScrollTrigger'

gsap.registerPlugin(ScrollTrigger)

type MediaItem = {
  muxPlaybackId?: string
  imageSrc?: string
  title?: string
  views?: string
  platform?: string
}

type Props = {
  items?: MediaItem[]
  className?: string
}

const defaultItems: MediaItem[] = [
  // Top row - 3 items
  { muxPlaybackId: 'ocsdUVPID4I15NPIBKhQDTLCSbZEZUha58J2pPnNv5c', title: 'Video 1', views: '1:00', platform: 'LinkedIn' },
  { muxPlaybackId: 'N14jtGvn5ll6g8C011IaH01Lie598aDe5ln00GozifDlOI', title: 'Video 2', views: '0:45', platform: 'LinkedIn' },
  { muxPlaybackId: '019suLWfXs02fyoXK83a54cSZ1kLHNx5Q8SUM9djwql01g', title: 'Video 3', views: '1:20', platform: 'LinkedIn' },
  // Middle row - 4 items
  { muxPlaybackId: 'VndGErsM3QK1xXMroEhfLeFfDWt201JM9t6rXwTURfrc', title: 'Video 4', views: '0:50', platform: 'LinkedIn' },
  { muxPlaybackId: 'yHw2hFubBPWVVguxZqJKmLBY01DV02bMIffu1rSxMOM2A', title: 'Video 5', views: '1:15', platform: 'LinkedIn' },
  { muxPlaybackId: 'rOfhTc8aEUJuR01Fyemjsd101m85IsDHGX0136TFmKeQnY', title: 'Video 6', views: '0:55', platform: 'LinkedIn' },
  { muxPlaybackId: '3DiuqKvw8qQ1hZ1gatEI3MJDJNA98gTctBY7OyYLCN4', title: 'Video 7', views: '1:10', platform: 'LinkedIn' },
  // Bottom row - 3 items
  { muxPlaybackId: 'XfffetRXKDX85zjnJAaCtZPCG3k44xl3D02NIVzFMB4Q', title: 'Video 8', views: '0:40', platform: 'LinkedIn' },
  { muxPlaybackId: 'THcyz02Sha9WUns1ZfkSxXnUcN5WLylF73jKl8XKTuqo', title: 'Video 9', views: '1:05', platform: 'LinkedIn' },
  { muxPlaybackId: 'UCX011D02kR01MWSz5GMvtLnb5MvSaYJl3ZIEmAVLvMVF8', title: 'Video 10', views: '0:58', platform: 'LinkedIn' },
]

const MediaSlider: React.FC<Props> = ({ items = defaultItems, className = '' }) => {
  const sectionRef = useRef<HTMLDivElement>(null)
  const row2Ref = useRef<HTMLDivElement>(null)
  const row3Ref = useRef<HTMLDivElement>(null)

  useEffect(() => {
    if (!sectionRef.current || !row2Ref.current || !row3Ref.current) return

    const ctx = gsap.context(() => {
      // Row 2 moves left
      gsap.to(row2Ref.current, {
        x: -200,
        ease: 'none',
        scrollTrigger: {
          trigger: sectionRef.current,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1,
        }
      })

      // Row 3 moves right
      gsap.to(row3Ref.current, {
        x: 200,
        ease: 'none',
        scrollTrigger: {
          trigger: sectionRef.current,
          start: 'top bottom',
          end: 'bottom top',
          scrub: 1,
        }
      })
    }, sectionRef)

    return () => ctx.revert()
  }, [])

  const getImageSrc = (item: MediaItem) => {
    if (item.imageSrc) return item.imageSrc
    if (item.muxPlaybackId) return `https://image.mux.com/${item.muxPlaybackId}/thumbnail.jpg`
    return '/placeholder.jpg'
  }

  return (
    <section ref={sectionRef} className={`relative w-full min-h-screen py-20 overflow-hidden ${className}`}>
      {/* Video Grid Background - 3, 4, 3 layout */}
      <div className="absolute inset-0 flex flex-col justify-center gap-2 p-8">
        {/* Top row - 3 items (static) */}
        <div className="flex gap-2 justify-center">
          {items.slice(0, 3).map((item, i) => (
            <div key={i} className="relative w-80 aspect-video rounded-lg overflow-hidden shadow-xl">
              {/* Blur background */}
              <div 
                className="absolute inset-0"
                style={{
                  backgroundImage: `url(https://image.mux.com/${item.muxPlaybackId}/thumbnail.jpg)`,
                  backgroundSize: 'cover',
                  backgroundPosition: 'center',
                  filter: 'blur(20px)',
                  transform: 'scale(1.1)',
                }}
              />
              
              {/* Video layer */}
              <div className="relative z-10 w-full h-full">
                <MuxPlayer
                  playbackId={item.muxPlaybackId}
                  playsInline
                  metadata={{
                    video_id: `video-${i}`,
                    video_title: item.title || `Video ${i + 1}`,
                    viewer_user_id: "user-id-007",
                  }}
                  style={{
                    width: '100%',
                    height: '100%',
                    '--media-object-fit': 'contain',
                    '--media-background-color': 'transparent',
                    '--controls-background-color': 'transparent',
                  } as React.CSSProperties}
                />
              </div>
            </div>
          ))}
        </div>
        
        {/* Middle row - 4 items (moves left) */}
        <div ref={row2Ref} className="flex gap-2 justify-center">
          {items.slice(3, 7).map((item, i) => (
            <div key={i + 3} className="relative w-80 aspect-video rounded-lg overflow-hidden shadow-xl">
              {/* Blur background */}
              <div 
                className="absolute inset-0"
                style={{
                  backgroundImage: `url(https://image.mux.com/${item.muxPlaybackId}/thumbnail.jpg)`,
                  backgroundSize: 'cover',
                  backgroundPosition: 'center',
                  filter: 'blur(20px)',
                  transform: 'scale(1.1)',
                }}
              />
              
              {/* Video layer */}
              <div className="relative z-10 w-full h-full">
                <MuxPlayer
                  playbackId={item.muxPlaybackId}
                  playsInline
                  metadata={{
                    video_id: `video-${i + 3}`,
                    video_title: item.title || `Video ${i + 4}`,
                    viewer_user_id: "user-id-007",
                  }}
                  style={{
                    width: '100%',
                    height: '100%',
                    '--media-object-fit': 'contain',
                    '--media-background-color': 'transparent',
                    '--controls-background-color': 'transparent',
                  } as React.CSSProperties}
                />
              </div>
            </div>
          ))}
        </div>
        
        {/* Bottom row - 3 items (moves right) */}
        <div ref={row3Ref} className="flex gap-2 justify-center">
          {items.slice(7, 10).map((item, i) => (
            <div key={i + 7} className="relative w-80 aspect-video rounded-lg overflow-hidden shadow-xl">
              {/* Blur background */}
              <div 
                className="absolute inset-0"
                style={{
                  backgroundImage: `url(https://image.mux.com/${item.muxPlaybackId}/thumbnail.jpg)`,
                  backgroundSize: 'cover',
                  backgroundPosition: 'center',
                  filter: 'blur(20px)',
                  transform: 'scale(1.1)',
                }}
              />
              
              {/* Video layer */}
              <div className="relative z-10 w-full h-full">
                <MuxPlayer
                  playbackId={item.muxPlaybackId}
                  playsInline
                  metadata={{
                    video_id: `video-${i + 7}`,
                    video_title: item.title || `Video ${i + 8}`,
                    viewer_user_id: "user-id-007",
                  }}
                  style={{
                    width: '100%',
                    height: '100%',
                    '--media-object-fit': 'contain',
                    '--media-background-color': 'transparent',
                    '--controls-background-color': 'transparent',
                  } as React.CSSProperties}
                />
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Dark Gradient Overlay from left */}
      <div className="absolute inset-0 bg-gradient-to-r from-black via-black/95 to-transparent md:to-transparent pointer-events-none" />

      {/* Content Section - Overlays the grid */}
      <div className="relative z-10 max-w-7xl mx-auto px-8 md:px-16 min-h-screen flex items-center">
        <div className="max-w-xl">
          <h2 className="text-white text-5xl md:text-6xl lg:text-7xl font-bold mb-6 leading-tight">
            Media & Content.
          </h2>
          <p className="text-white/80 text-lg md:text-xl mb-8 leading-relaxed">
            Explore my latest LinkedIn video creations, keynotes, and insights. Combining expertise with authentic enthusiasm to deliver impactful content.
          </p>
          
          <div className="flex gap-4">
            <button className="px-6 py-3 bg-white text-black rounded-full font-semibold hover:bg-white/90 transition-all duration-300">
              About Us
            </button>
            <button className="px-6 py-3 bg-white/10 backdrop-blur-sm text-white rounded-full font-semibold hover:bg-white/20 transition-all duration-300">
              See our work
            </button>
          </div>
        </div>
      </div>
    </section>
  )
}

export default MediaSlider